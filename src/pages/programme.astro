---
import Layout from '../layouts/Layout.astro';
import PocketBase from 'pocketbase';

const pb = new PocketBase('http://127.0.0.1:8090');

const allProgramme = await pb.collection('programme').getFullList({
  sort: 'date',
  expand: 'artiste,scene',
});

function toDate(value) {
  return new Date(value);
}

function getDayKey(dateValue) {
  const d = toDate(dateValue);
  const year = d.getFullYear();
  const month = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}

function formatDayTab(dateValue) {
  const d = toDate(dateValue);
  const weekday = new Intl.DateTimeFormat('fr-FR', { weekday: 'long' }).format(d);
  const day = new Intl.DateTimeFormat('fr-FR', { day: 'numeric' }).format(d);

  const weekdayCap = weekday.charAt(0).toUpperCase() + weekday.slice(1);
  return `${weekdayCap} ${day}`;
}

function formatTime(dateValue) {
  return new Intl.DateTimeFormat('fr-FR', {
    hour: '2-digit',
    minute: '2-digit',
  }).format(toDate(dateValue));
}

function formatTimeRange(dateValue) {
  const start = toDate(dateValue);
  const end = new Date(start.getTime() + 60 * 60 * 1000);

  return `${formatTime(start)} - ${formatTime(end)}`;
}

function getArtistName(item) {
  return item.expand?.artiste?.nom ?? 'Artiste';
}

function getGenre(item) {
  return item.expand?.artiste?.genre_musical ?? 'Inconnu';
}

function getSceneName(item) {
  return item.expand?.scene?.nom ?? 'Scène inconnue';
}

function slugify(value) {
  return value
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .toLowerCase()
    .trim();
}

function getGradientClass(genre) {
  const g = slugify(genre);

  if (g.includes('rock')) return 'from-cyan-400 to-blue-500';
  if (g.includes('jazz')) return 'from-emerald-400 to-blue-500';
  if (g.includes('electro')) return 'from-fuchsia-400 to-pink-500';
  if (g.includes('hip-hop') || g.includes('hip hop') || g.includes('rap')) return 'from-orange-400 to-red-500';
  if (g.includes('folk')) return 'from-cyan-400 to-blue-500';
  if (g.includes('pop')) return 'from-pink-400 to-fuchsia-500';
  return 'from-slate-400 to-slate-600';
}

function getBadgeClass(genre) {
  const g = slugify(genre);

  if (g.includes('rock')) return 'bg-blue-100 text-blue-700';
  if (g.includes('jazz')) return 'bg-yellow-100 text-yellow-700';
  if (g.includes('electro')) return 'bg-purple-100 text-purple-700';
  if (g.includes('hip-hop') || g.includes('hip hop') || g.includes('rap')) return 'bg-slate-200 text-slate-700';
  if (g.includes('folk')) return 'bg-green-100 text-green-700';
  if (g.includes('pop')) return 'bg-pink-100 text-pink-700';
  return 'bg-slate-100 text-slate-700';
}

function getIconName(genre) {
  const g = slugify(genre);

  if (g.includes('rock')) return 'guitar';
  if (g.includes('jazz')) return 'guitar';
  if (g.includes('electro')) return 'mic';
  if (g.includes('hip-hop') || g.includes('hip hop') || g.includes('rap')) return 'drum';
  if (g.includes('folk')) return 'note';
  if (g.includes('pop')) return 'note';
  return 'note';
}

const days = [...new Set(allProgramme.map((item) => getDayKey(item.date)))];

const genres = [...new Set(allProgramme.map((item) => getGenre(item)))].sort((a, b) =>
  a.localeCompare(b, 'fr')
);

const scenes = [...new Set(allProgramme.map((item) => getSceneName(item)))].sort((a, b) =>
  a.localeCompare(b, 'fr')
);

const selectedDay =
  Astro.url.searchParams.get('jour') && days.includes(Astro.url.searchParams.get('jour'))
    ? Astro.url.searchParams.get('jour')
    : days[0] ?? '';

const selectedGenre = Astro.url.searchParams.get('genre') ?? '';
const selectedScene = Astro.url.searchParams.get('scene') ?? '';

const filteredProgramme = allProgramme.filter((item) => {
  const matchDay = selectedDay ? getDayKey(item.date) === selectedDay : true;
  const matchGenre = selectedGenre ? getGenre(item) === selectedGenre : true;
  const matchScene = selectedScene ? getSceneName(item) === selectedScene : true;
  return matchDay && matchGenre && matchScene;
});

const groupedByTime = Object.values(
  filteredProgramme.reduce((acc, item) => {
    const key = formatTimeRange(item.date);

    if (!acc[key]) {
      acc[key] = {
        time: key,
        items: [],
      };
    }

    acc[key].items.push(item);
    return acc;
  }, {})
);

function buildProgrammeUrl(day, genre, scene) {
  const params = new URLSearchParams();

  if (day) params.set('jour', day);
  if (genre) params.set('genre', genre);
  if (scene) params.set('scene', scene);

  const query = params.toString();
  return query ? `/programme?${query}` : '/programme';
}
---

<Layout titre="Programme">
  <main class="min-h-screen bg-[#f3f3f4] text-[#1b2233]">

    <section class="border-b border-black/5 bg-white px-6 py-5 shadow-[0_1px_0_rgba(0,0,0,0.04)]">
      <div class="mx-auto max-w-5xl">
        <div class="flex items-center justify-between">
          <a href="/" aria-label="Retour à l'accueil" class="inline-flex h-10 w-10 items-center justify-center text-slate-600 transition hover:text-slate-900">
            <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 18l-6-6 6-6" />
            </svg>
          </a>

          <h1 class="text-2xl font-black tracking-tight text-slate-900">Programme</h1>

          <button type="button" aria-label="Partager" class="inline-flex h-10 w-10 items-center justify-center text-slate-600 transition hover:text-slate-900">
            <svg viewBox="0 0 24 24" class="h-7 w-7" fill="currentColor">
              <path d="M18 16a3 3 0 0 0-2.39 1.2l-6.2-3.1a3.36 3.36 0 0 0 0-1.2l6.2-3.1A3 3 0 1 0 15 8a2.6 2.6 0 0 0 .07.6l-6.16 3.08a3 3 0 1 0 0 4.64l6.16 3.08A2.6 2.6 0 0 0 15 20a3 3 0 1 0 3-4Z" />
            </svg>
          </button>
        </div>
      </div>
    </section>

    <section class="px-6 py-6 border-b border-black/5 bg-white">
      <div class="mx-auto max-w-5xl">
        <div class="flex gap-3 overflow-x-auto pb-2">
          {days.map((day) => {
            const isActive = day === selectedDay;
            return (
              <a
                href={buildProgrammeUrl(day, selectedGenre, selectedScene)}
                class={`shrink-0 rounded-full px-6 py-3 text-base font-semibold transition ${
                  isActive ? 'bg-[#a9c8f7] text-slate-900' : 'bg-[#e8e8eb] text-slate-700 hover:bg-[#dedee3]'
                }`}
              >
                {formatDayTab(day)}
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="px-6 py-6">
      <div class="mx-auto max-w-5xl space-y-4">

        <div class="grid gap-3 md:grid-cols-2">
          <form method="GET" class="contents">
            <input type="hidden" name="jour" value={selectedDay} />
            {selectedScene && <input type="hidden" name="scene" value={selectedScene} />}

            <label class="block">
              <span class="sr-only">Filtrer par genre</span>
              <div class="relative">
                <select
                  name="genre"
                  onchange="this.form.submit()"
                  class="w-full appearance-none rounded-[18px] border-2 border-black bg-white px-5 py-3 pr-14 text-base text-slate-700 outline-none font-medium"
                >
                  <option value="">Tous les genres</option>
                  {genres.map((genre) => (
                    <option value={genre} selected={genre === selectedGenre}>
                      {genre}
                    </option>
                  ))}
                </select>
                <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 text-2xl text-slate-500">˅</span>
              </div>
            </label>
          </form>

          <form method="GET" class="contents">
            <input type="hidden" name="jour" value={selectedDay} />
            {selectedGenre && <input type="hidden" name="genre" value={selectedGenre} />}

            <label class="block">
              <span class="sr-only">Filtrer par scène</span>
              <div class="relative">
                <select
                  name="scene"
                  onchange="this.form.submit()"
                  class="w-full appearance-none rounded-[18px] border-2 border-black bg-white px-5 py-3 pr-14 text-base text-slate-700 outline-none font-medium"
                >
                  <option value="">Toutes les scènes</option>
                  {scenes.map((scene) => (
                    <option value={scene} selected={scene === selectedScene}>
                      {scene}
                    </option>
                  ))}
                </select>
                <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 text-2xl text-slate-500">˅</span>
              </div>
            </label>
          </form>
        </div>

        <a
          href="/pdf/programme-festival.pdf"
          target="_blank"
          class="flex items-center justify-center gap-3 rounded-[22px] bg-[#a9c8f7] px-6 py-4 text-center text-lg font-semibold text-slate-900 shadow-md transition hover:brightness-95"
        >
          <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3v11" />
            <path d="M7 10l5 5 5-5" />
            <path d="M5 21h14" />
          </svg>
          Télécharger le programme PDF
        </a>
      </div>
    </section>

    <section class="px-6 pb-12">
      <div class="mx-auto max-w-5xl space-y-8">
        {groupedByTime.length === 0 ? (
          <div class="rounded-3xl bg-white p-10 text-center shadow-sm">
            <p class="text-lg text-slate-600">Aucun concert ne correspond à ces filtres.</p>
          </div>
        ) : (
          groupedByTime.map((group) => (
            <div>
              <!-- Heure -->
              <h2 class="mb-4 text-lg font-black text-slate-900">{group.time}</h2>

              <!-- Cartes des artistes -->
              <div class="space-y-3">
                {group.items.map((item) => {
                  const artistName = getArtistName(item);
                  const genre = getGenre(item);
                  const sceneName = getSceneName(item);
                  const artistId = item.expand?.artiste?.id;
                  const sceneId = item.expand?.scene?.id;
                  const iconName = getIconName(genre);

                  return (
                    <div class="flex items-center gap-4 rounded-xl bg-white p-4 shadow-sm">
                      <!-- Icône/Image carrée -->
                      <div class={`flex h-16 w-16 shrink-0 items-center justify-center rounded-lg bg-gradient-to-br text-white ${getGradientClass(genre)}`}>
                        {iconName === 'mic' && (
                          <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="9" y="3" width="6" height="11" rx="3" />
                            <path d="M19 10a7 7 0 0 1-14 0" />
                            <path d="M12 17v4" />
                            <path d="M8 21h8" />
                          </svg>
                        )}

                        {iconName === 'guitar' && (
                          <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14.5 5.5 18 2l4 4-3.5 3.5" />
                            <path d="M12 8 7 13a4.2 4.2 0 1 0 6 6l5-5" />
                            <path d="M10 10l4 4" />
                          </svg>
                        )}

                        {iconName === 'drum' && (
                          <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <ellipse cx="12" cy="8" rx="6" ry="3" />
                            <path d="M6 8v8c0 1.7 2.7 3 6 3s6-1.3 6-3V8" />
                            <path d="M4 4l4 4" />
                            <path d="M20 4l-4 4" />
                          </svg>
                        )}

                        {iconName === 'note' && (
                          <svg viewBox="0 0 24 24" class="h-8 w-8" fill="currentColor">
                            <path d="M14 3v10.55A4 4 0 1 0 16 17V8h4V3h-6Z" />
                          </svg>
                        )}
                      </div>

                      <!-- Infos artiste -->
                      <div class="min-w-0 flex-1">
                        <a href={artistId ? `/artistes/${artistId}` : '#'} class="block text-lg font-black text-slate-900 hover:underline">
                          {artistName}
                        </a>

                        <div class="mt-2 flex flex-wrap items-center gap-3">
                          <span class={`rounded-full px-3 py-1 text-xs font-semibold ${getBadgeClass(genre)}`}>{genre}</span>

                          <div class="flex items-center gap-1.5 text-sm text-slate-600">
                            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current">
                              <path d="M12 2a7 7 0 0 0-7 7c0 4.8 5.7 11.6 6 11.9a1.3 1.3 0 0 0 2 0c.3-.3 6-7.1 6-11.9a7 7 0 0 0-7-7Zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5Z" />
                            </svg>
                            <a href={sceneId ? `/scenes/${sceneId}` : '#'} class="hover:underline">
                              {sceneName}
                            </a>
                          </div>
                        </div>
                      </div>

                      <!-- Cœur favoris -->
                      <button type="button" class="favorite-btn shrink-0 text-slate-400 transition hover:scale-110" data-id={item.id} aria-label="Ajouter aux favoris">
                        <span class="heart-outline block">
                          <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z" />
                          </svg>
                        </span>

                        <span class="heart-filled hidden text-red-500">
                          <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor">
                            <path d="M12 21s-7.1-4.5-9.5-9.1A5.9 5.9 0 0 1 12 4.8a5.9 5.9 0 0 1 9.5 7.1C19.1 16.5 12 21 12 21Z" />
                          </svg>
                        </span>
                      </button>
                    </div>
                  );
                })}
              </div>
            </div>
          ))
        )}
      </div>
    </section>
  </main>

  <script>
    const storageKey = 'festival-favoris-programme';

    function getFavorites() {
      try {
        return JSON.parse(localStorage.getItem(storageKey) || '[]');
      } catch {
        return [];
      }
    }

    function saveFavorites(favorites) {
      localStorage.setItem(storageKey, JSON.stringify(favorites));
    }

    function refreshFavorites() {
      const favorites = getFavorites();

      document.querySelectorAll('.favorite-btn').forEach((button) => {
        const id = button.dataset.id;
        const isFavorite = favorites.includes(id);

        const outline = button.querySelector('.heart-outline');
        const filled = button.querySelector('.heart-filled');

        if (outline && filled) {
          outline.classList.toggle('hidden', isFavorite);
          filled.classList.toggle('hidden', !isFavorite);
        }
      });
    }

    refreshFavorites();

    document.querySelectorAll('.favorite-btn').forEach((button) => {
      button.addEventListener('click', () => {
        const id = button.dataset.id;
        const favorites = getFavorites();

        if (favorites.includes(id)) {
          saveFavorites(favorites.filter((fav) => fav !== id));
        } else {
          saveFavorites([...favorites, id]);
        }

        refreshFavorites();
      });
    });
  </script>
      <nav class="fixed bottom-0 left-0 right-0 flex justify-around bg-white border-t border-slate-200 px-4 py-3">
      <a href="/" class="flex flex-col items-center gap-1 text-xs font-semibold text-slate-600 hover:text-slate-900">
        Accueil
      </a>
      <a href="/artistes" class="flex flex-col items-center gap-1 text-xs font-semibold text-slate-600 hover:text-slate-900">
        Artistes
      </a>
      <a href="/infos-pratiques" class="flex flex-col items-center gap-1 text-xs font-semibold text-[#4f9ef7]">
        Infos Pratiques
      </a>
      <a href="/contact" class="flex flex-col items-center gap-1 text-xs font-semibold text-slate-600 hover:text-slate-900">
        Contact
      </a>
    </nav>
</Layout>
