---
import Layout from '../layouts/Layout.astro';
---

<Layout titre="Infos pratiques">
  <section class="px-6 py-12">
    <h1 class="mb-6 text-4xl font-bold">Infos pratiques</h1>

    <div class="space-y-8">
      <section>
        <h2 class="mb-2 text-2xl font-semibold">Tarifs</h2>
        <p>Pass 1 jour, pass 2 jours, tarifs réduits.</p>
      </section>

      <section>
        <h2 class="mb-2 text-2xl font-semibold">Hébergements</h2>
        <p>Hôtels, campings et hébergements partenaires.</p>
      </section>

      <section>
        <h2 class="mb-2 text-2xl font-semibold">Transport</h2>
        <p>Train, voiture, covoiturage, parkings et accès au site.</p>
      </section>

      <section>
        <h2 class="mb-2 text-2xl font-semibold">FAQ</h2>
        <p>Questions fréquentes sur le festival.</p>
      </section>
    </div>
  </section>
</Layout>