---
import Layout from '../../layouts/Layout.astro';
import PocketBase from 'pocketbase';

const pb = new PocketBase('http://127.0.0.1:8090');
const { id } = Astro.params;

const artiste = await pb.collection('artistes').getOne(id);

const passages = await pb.collection('programme').getFullList({
  filter: `artiste = "${id}"`,
  sort: 'date',
  expand: 'scene'
});

function toDate(value: string | number | Date): Date {
  return new Date(value);
}

function formatDatePassageFull(dateValue: string | number | Date): string {
  const d = toDate(dateValue);
  const day = new Intl.DateTimeFormat('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }).format(d);
  const time = new Intl.DateTimeFormat('fr-FR', { hour: '2-digit', minute: '2-digit' }).format(d);
  return `${day[0].toUpperCase() + day.slice(1)} ${time}`;
}

function getImageUrl(artiste: any): string | null {
  const imageField = artiste.photo_artiste;
  if (imageField) {
    return `http://127.0.0.1:8090/api/files/artistes/${artiste.id}/${imageField}`;
  }
  return null;
}

function getGalerieUrls(artiste: any): string[] {
  const images: string[] = [];
  if (artiste.gallerie_photo) {
    // Si c'est un tableau de fichiers
    if (Array.isArray(artiste.gallerie_photo)) {
      artiste.gallerie_photo.forEach((file: string) => {
        images.push(`http://127.0.0.1:8090/api/files/artistes/${artiste.id}/${file}`);
      });
    } else if (typeof artiste.gallerie_photo === 'string') {
      // Si c'est une seule image
      images.push(`http://127.0.0.1:8090/api/files/artistes/${artiste.id}/${artiste.gallerie_photo}`);
    }
  }
  return images;
}

const firstPassage = passages[0];
const galerieImages = getGalerieUrls(artiste);
---

<Layout titre={artiste.nom}>
  <main class="min-h-screen bg-blue-300">
    <!-- Hero avec image de fond -->
    <div class="relative h-96 overflow-hidden rounded-3xl">
      {getImageUrl(artiste) ? (
        <img src={getImageUrl(artiste)} alt={artiste.nom} class="h-full w-full object-cover" />
      ) : (
        <div class="h-full w-full bg-gradient-to-br from-slate-300 to-slate-400" />
      )}
    
      
      <!-- Retour -->
      <a href="/artistes" class="absolute top-6 left-6 flex h-12 w-12 items-center justify-center rounded-full bg-white/30 backdrop-blur text-white hover:bg-white/50 transition">
        <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M15 18l-6-6 6-6" />
        </svg>
      </a>
    </div>

    <div class="px-6 py-8">
      <div class="mx-auto max-w-2xl">
        <!-- Carte avec infos -->
        <div class="rounded-3xl bg-white/10 backdrop-blur-md p-8 -mt-32 relative z-10 border border-white/20">
          <!-- Badge En vedette -->
          <div class="mb-6 inline-block">
            <span class="rounded-full border border-white/50 px-4 py-2 text-sm font-semibold text-white">
              En vedette
            </span>
          </div>

          <!-- Nom -->
          <h1 class="mb-4 text-4xl font-black text-white">
            {artiste.nom}
          </h1>

          <!-- Date et lieu -->
          {firstPassage && (
            <div class="mb-6 space-y-2">
              <div class="flex items-center gap-2 text-lg text-white/90">
                <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                </svg>
                {formatDatePassageFull(firstPassage.date)}
              </div>
              <div class="flex items-center gap-2 text-lg text-white/90">
                <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 2a7 7 0 0 0-7 7c0 4.8 5.7 11.6 6 11.9a1.3 1.3 0 0 0 2 0c.3-.3 6-7.1 6-11.9a7 7 0 0 0-7-7Zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5Z" />
                </svg>
                {firstPassage.expand?.scene?.nom}
              </div>
            </div>
          )}

          <!-- Genres -->
          <div class="mb-6 flex flex-wrap gap-2">
            {artiste.genre_musical && (
              <span class="rounded-full border border-white/50 px-4 py-2 text-sm font-semibold text-white">
                {artiste.genre_musical}
              </span>
            )}
          </div>

          <!-- Description -->
          {artiste.description && (
            <p class="mb-6 text-base leading-relaxed text-white/80">
              {artiste.description}
            </p>
          )}

          <!-- Boutons -->
          <div class="flex gap-3">
            <button class="rounded-full bg-white px-6 py-3 font-semibold text-gray-900 hover:bg-white/90 transition">
              Rappel
            </button>
            <button class="rounded-full border border-white/50 w-12 h-12 flex items-center justify-center hover:bg-white/10 transition">
              <svg viewBox="0 0 24 24" class="h-6 w-6 stroke-white" fill="none" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Statistiques -->
        <div class="mt-8 grid grid-cols-3 gap-4">
          <div class="rounded-2xl bg-white/10 backdrop-blur-md p-6 text-center border border-white/20">
            <div class="text-2xl font-black text-white">127K</div>
            <div class="text-sm text-white/70 mt-1">Fans</div>
          </div>
          <div class="rounded-2xl bg-white/10 backdrop-blur-md p-6 text-center border border-white/20">
            <div class="text-2xl font-black text-white">3.2M</div>
            <div class="text-sm text-white/70 mt-1">Écoutés</div>
          </div>
          <div class="rounded-2xl bg-white/10 backdrop-blur-md p-6 text-center border border-white/20">
            <div class="text-2xl font-black text-white">{passages.length}</div>
            <div class="text-sm text-white/70 mt-1">Concerts</div>
          </div>
        </div>

        <!-- Galerie -->
        {galerieImages.length > 0 && (
          <div class="mt-12">
            <h2 class="mb-6 text-3xl font-black text-white">Galerie</h2>
            <div class="overflow-x-auto pb-4 -mx-6 px-6">
              <div class="flex gap-4 w-max">
                {galerieImages.map((image: string) => (
                  <img
                    src={image}
                    alt="Galerie"
                    class="h-64 w-64 rounded-2xl object-cover flex-shrink-0"
                  />
                ))}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  </main>

  <script>
    const storageKey = 'festival-favoris-artistes';

    function getFavorites(): string[] {
      try {
        return JSON.parse(localStorage.getItem(storageKey) || '[]');
      } catch {
        return [];
      }
    }

    function saveFavorites(favorites: string[]): void {
      localStorage.setItem(storageKey, JSON.stringify(favorites));
    }
  </script>
</Layout>