---
import Layout from '../layouts/Layout.astro';
---

<Layout titre="À propos">
  <section class="px-6 py-12">
    <h1 class="mb-6 text-4xl font-bold">À propos</h1>

    <div class="space-y-8">
      <section>
        <h2 class="mb-2 text-2xl font-semibold">Historique</h2>
        <p>Présentation du festival, sa création et ses objectifs.</p>
      </section>

      <section>
        <h2 class="mb-2 text-2xl font-semibold">Équipe</h2>
        <p>Organisateurs, régie, technique et bénévoles.</p>
      </section>

      <section>
        <h2 class="mb-2 text-2xl font-semibold">Charte</h2>
        <p>Valeurs du festival et thématique de l’édition 2026.</p>
      </section>
    </div>
  </section>
</Layout>