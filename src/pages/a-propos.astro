---
import Layout from '../layouts/Layout.astro';

const historique = [
  {
    numero: 1,
    annee: '2010',
    titre: 'Les débuts',
    texte:
      "Création du festival avec une vision simple : rassembler les artistes locaux et créer des liens authentiques avec le public.",
    bg: 'bg-blue-300',
    text: 'text-white',
  },
  {
    numero: 2,
    annee: '2015',
    titre: 'Expansion',
    texte:
      "Ouverture à des artistes internationaux tout en gardant notre identité locale et notre engagement écologique.",
    bg: 'bg-blue-500',
    text: 'text-white',
  },
  {
    numero: 3,
    annee: '2020',
    titre: 'Adaptation',
    texte:
      "Réinvention du format avec des expériences hybrides et un engagement renforcé pour la durabilité.",
    bg: 'bg-blue-950',
    text: 'text-white',
  },
];

const equipe = [
  {
    nom: 'Sienna Mcguire',
    role: 'Directrice artistique',
    description: 'Passionnée de musique depuis 15 ans',
    photo: '/public/sienna.avif',
  },
  {
    nom: 'Jason Cooper',
    role: 'Coordinateur évènements',
    description: 'Expert en production culturelle',
    photo: '/public/jason.avif',
  },
  {
    nom: 'Chloé Reese',
    role: 'Responsable durabilité',
    description: 'Spécialiste en évènements éco-responsables',
    photo: '/public/chloe.avif',
  },
];

const valeurs = [
  {
    titre: 'Créativité',
    texte:
      "Nous encourageons l'innovation artistique et offrons une plateforme aux talents émergents pour exprimer leur vision unique.",
    bg: 'bg-blue-200',
    iconBg: 'bg-blue-900',
    icon: '💡',
  },
  {
    titre: 'Proximité',
    texte:
      "Nous créons des liens authentiques entre artistes et public, privilégiant les rencontres humaines et les échanges sincères.",
    bg: 'bg-pink-200',
    iconBg: 'bg-pink-500',
    icon: '🤝',
  },
  {
    titre: 'Durabilité',
    texte:
      "Nous nous engageons pour un festival éco-responsable, respectueux de l'environnement et des générations futures.",
    bg: 'bg-green-200',
    iconBg: 'bg-green-700',
    icon: '🍃',
  },
];

const galerie = [
  '/public/gallerie.avif',
  '/public/gallerie2.avif',
  '/public/gallerie3.avif',
];
---

<Layout titre="À propos">
  <main class="bg-neutral-100 text-slate-900">
    <section class="bg-gradient-to-r from-blue-500 to-blue-300 px-6 py-14 text-center">
      <div class="mx-auto max-w-3xl">
        <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-white/30 text-5xl text-white">
          ♪
        </div>

        <h1 class="mt-6 text-4xl font-black tracking-tight text-slate-900 md:text-5xl">
          À propos du Festival
        </h1>

        <p class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-slate-700">
          Découvrez l'histoire, l'équipe et les valeurs qui font de notre festival
          un évènement unique
        </p>
      </div>
    </section>

    <section class="px-6 py-10 md:py-14">
      <div class="mx-auto max-w-5xl">
        <div class="mb-8 flex items-center gap-3">
          <span class="text-2xl text-blue-300">↺</span>
          <h2 class="text-3xl font-black tracking-tight">Historique</h2>
        </div>

        <div class="space-y-5">
          {historique.map((item) => (
            <article class="rounded-3xl bg-neutral-50 p-5 shadow-sm ring-1 ring-black/5">
              <div class="flex items-start gap-4">
                <div class={`flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-bold ${item.bg} ${item.text}`}>
                  {item.numero}
                </div>

                <div>
                  <h3 class="text-2xl font-semibold leading-tight text-slate-900">
                    {item.annee} - {item.titre}
                  </h3>
                  <p class="mt-2 text-lg leading-8 text-slate-600">
                    {item.texte}
                  </p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-neutral-200 px-6 py-10 md:py-14">
      <div class="mx-auto max-w-5xl">
        <div class="mb-8 flex items-center gap-3">
          <span class="text-2xl text-blue-500">👥</span>
          <h2 class="text-3xl font-black tracking-tight">Notre équipe</h2>
        </div>

        <div class="space-y-5">
          {equipe.map((personne) => (
            <article class="rounded-3xl bg-neutral-50 p-5 shadow-sm ring-1 ring-black/5">
              <div class="flex items-start gap-4">
                <img
                  src={personne.photo}
                  alt={personne.nom}
                  class="h-14 w-14 rounded-full object-cover"
                />

                <div>
                  <h3 class="text-2xl font-semibold leading-tight">{personne.nom}</h3>
                  <p class="mt-1 text-lg font-medium text-blue-700">{personne.role}</p>
                  <p class="mt-1 text-base leading-7 text-slate-600">
                    {personne.description}
                  </p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 py-10 md:py-14">
      <div class="mx-auto max-w-5xl">
        <div class="mb-8 flex items-center gap-3">
          <span class="text-2xl text-blue-800">♥</span>
          <h2 class="text-3xl font-black tracking-tight">Nos valeurs</h2>
        </div>

        <div class="space-y-5">
          {valeurs.map((valeur) => (
            <article class={`rounded-3xl p-6 shadow-sm ring-1 ring-black/5 ${valeur.bg}`}>
              <div class="flex items-start gap-4">
                <div class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-xl text-white ${valeur.iconBg}`}>
                  {valeur.icon}
                </div>

                <div>
                  <h3 class="text-2xl font-bold">{valeur.titre}</h3>
                  <p class="mt-4 text-lg leading-8 text-slate-800">
                    {valeur.texte}
                  </p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-neutral-200 px-6 py-10 md:py-14">
      <div class="mx-auto max-w-5xl">
        <div class="mb-8 flex items-center gap-3">
          <span class="text-2xl text-blue-800">📷</span>
          <h2 class="text-3xl font-black tracking-tight">Galerie photos</h2>
        </div>

        <div class="overflow-x-auto pb-4">
          <div class="flex gap-4">
            {galerie.map((image) => (
              <img
                src={image}
                alt="Photo du festival"
                class="h-64 w-[280px] shrink-0 rounded-3xl object-cover shadow-sm"
              />
            ))}
          </div>
        </div>

        <div class="mt-5 flex justify-center gap-2">
          <span class="h-3 w-3 rounded-full bg-violet-500"></span>
          <span class="h-3 w-3 rounded-full bg-slate-300"></span>
          <span class="h-3 w-3 rounded-full bg-slate-300"></span>
          <span class="h-3 w-3 rounded-full bg-slate-300"></span>
        </div>
      </div>
    </section>
  </main>
</Layout>