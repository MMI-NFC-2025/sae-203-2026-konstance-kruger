---
import Layout from '../layouts/Layout.astro';
---

<Layout titre="Contact">
  <main class="min-h-screen bg-white pb-24">
    <section class="bg-linear-to-b from-[#a9c8f7] to-[#8eb3f0] px-4 py-4 sticky top-0 z-10">
      <div class="flex items-center justify-between mb-4">
        <a href="/" class="text-slate-700">
          <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M15 18l-6-6 6-6" />
          </svg>
        </a>
        <h1 class="text-xl font-black text-slate-900">Contact</h1>
        <button class="text-slate-700">
          <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor">
            <path d="M3 6h18M3 12h18M3 18h18" />
          </svg>
        </button>
      </div>
    </section>

    <div class="px-4 py-8">
      <div class="mx-auto max-w-2xl space-y-8">
        <div class="rounded-2xl bg-white p-6 shadow">
          <h2 class="mb-4 text-2xl font-black text-slate-900 flex items-center gap-2">
            <svg viewBox="0 0 24 24" class="h-6 w-6 text-blue-500" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2.5 12l19-11-6.5 11 6.5 11-19-11z" />
            </svg>
            Envoyez-nous un message
          </h2>
          <form class="space-y-4">
            <div class="space-y-1">
              <label class="block text-sm font-semibold text-slate-700">Nom complet</label>
              <input type="text" placeholder="Votre nom et prénom" class="w-full rounded-lg border border-slate-300 px-4 py-3 text-black focus:ring-2 focus:ring-blue-300" />
            </div>
            <div class="space-y-1">
              <label class="block text-sm font-semibold text-slate-700">Email</label>
              <input type="email" placeholder="votre@email.com" class="w-full rounded-lg border border-slate-300 px-4 py-3 focus:ring-2 text-black focus:ring-blue-300" />
            </div>
            <div class="space-y-1">
              <label class="block text-sm font-semibold text-slate-700">Sujet</label>
              <select class="w-full rounded-lg border border-slate-300 px-4 py-3 focus:ring-2 text-black focus:ring-blue-300">
                <option disabled selected>Choisir un sujet</option>
                <option>Billetterie</option>
                <option>Hébergement</option>
                <option>Accréditation</option>
                <option>Autre</option>
              </select>
            </div>
            <div class="space-y-1">
              <label class="block text-sm font-semibold text-slate-700">Message</label>
              <textarea rows="5" placeholder="Décrivez votre demande en détail..." class="w-full rounded-lg border text-black border-slate-300 px-4 py-3 focus:ring-2 focus:ring-blue-300"></textarea>
            </div>
            <button type="submit" class="w-full rounded-2xl bg-blue-500 px-6 py-3 text-white font-semibold flex items-center justify-center gap-2">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
                <path d="M2 21l19-9-19-9v7l15 2-15 2z" />
              </svg>
              Envoyer le message
            </button>
          </form>
        </div>

        <div class="rounded-2xl bg-white p-6 shadow">
          <h2 class="mb-4 text-2xl font-black text-slate-900 flex items-center gap-2">
            <svg viewBox="0 0 24 24" class="h-6 w-6 text-yellow-600" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 8v13h18V8M3 8l9-6 9 6" />
            </svg>
            Nos coordonnées
          </h2>
          <ul class="space-y-4 text-sm text-slate-700">
            <li class="flex items-start gap-3">
              <svg viewBox="0 0 24 24" class="h-6 w-6 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16v16H4z" />
                <path d="M22 8l-10 6-10-6" />
              </svg>
              <div>
                <span class="font-semibold">Email</span><br />
                contact@exemple.com<br />
                support@exemple.com
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg viewBox="0 0 24 24" class="h-6 w-6 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.63A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12 1.21.37 2.39.75 3.52a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.55-1.55a2 2 0 0 1 2.11-.45c1.13.38 2.31.63 3.52.75A2 2 0 0 1 22 16.92z" />
              </svg>
              <div>
                <span class="font-semibold">Téléphone</span><br />
                +33 1 23 45 67 89<br />
                Lun–Ven 9h–18h
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg viewBox="0 0 24 24" class="h-6 w-6 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 6-9 13-9 13s-9-7-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              <div>
                <span class="font-semibold">Adresse</span><br />
                X
              </div>
            </li>
          </ul>
        </div>

        <div class="rounded-2xl bg-white p-6 shadow">
          <h2 class="mb-4 text-2xl font-black text-slate-900 flex items-center gap-2">
            <svg viewBox="0 0 24 24" class="h-6 w-6 text-blue-500" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16v16H4z" />
              <path d="M22 8l-10 6-10-6" />
            </svg>
            Suivez-nous
          </h2>
          <div class="grid grid-cols-2 gap-4">
            <a href="#" class="rounded-lg bg-blue-50 flex items-center justify-center gap-2 py-3 text-blue-600 font-semibold">
              Twitter
            </a>
            <a href="#" class="rounded-lg bg-blue-50 flex items-center justify-center gap-2 py-3 text-blue-600 font-semibold">
              Facebook
            </a>
            <a href="#" class="rounded-lg bg-blue-50 flex items-center justify-center gap-2 py-3 text-blue-600 font-semibold">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">              </svg>
              LinkedIn
            </a>
            <a href="#" class="rounded-lg bg-pink-50 flex items-center justify-center gap-2 py-3 text-pink-500 font-semibold">
              Instagram
            </a>
          </div>
        </div>
      </div>
    </div>

    <nav class="fixed bottom-0 left-0 right-0 flex justify-around bg-white border-t border-slate-200 px-4 py-3">
      <a href="/" class="flex flex-col items-center gap-1 text-xs font-semibold text-slate-600 hover:text-slate-900">
        Accueil
      </a>
      <a href="/artistes" class="flex flex-col items-center gap-1 text-xs font-semibold text-slate-600 hover:text-slate-900">
        Artistes
      </a>
      <a href="/infos-pratiques" class="flex flex-col items-center gap-1 text-xs font-semibold text-[#4f9ef7]">
        Infos Pratiques
      </a>
      <a href="/contact" class="flex flex-col items-center gap-1 text-xs font-semibold text-slate-600 hover:text-slate-900">
        Contact
      </a>
    </nav>
  </main>
</Layout>