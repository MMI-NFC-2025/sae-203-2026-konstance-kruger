---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';


const { titre } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{titre}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
	<Footer />
  </body>
</html>

